{
  "manifest_version": 3,
  "name": "Country Screenshot Saver",
  "version": "1.0.0",
  "description": "Capture screenshots organized by country, date, and attribute",
  "browser_specific_settings": {
    "gecko": {
      "id": "country-screenshot-saver@kantar.dev",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "activeTab",
    "tabs",
    "downloads",
    "scripting",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Screenshot Saver - Sudhir Jangra"
  },
  "icons": {
    "96": "icons/favicon-96x96.png",
    "192": "icons/web-app-manifest-192x192.png",
    "512": "icons/web-app-manifest-512x512.png"
  }
}
